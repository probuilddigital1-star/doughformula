  // Download ICS calendar file
  document.getElementById('download-ics-btn')?.addEventListener('click', () => {
    const dateInput = document.getElementById('schedule-date') as HTMLInputElement;
    const timeInput = document.getElementById('schedule-time') as HTMLInputElement;

    if (!dateInput?.value || !timeInput?.value) return;

    const targetDate = new Date(`${dateInput.value}T${timeInput.value}`);
    const schedule = generateBakingSchedule(targetDate);

    // Generate ICS file content
    let icsContent = `BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//The Dough Formula//Baking Schedule//EN
`;

    schedule.forEach((item, index) => {
      const eventStart = new Date(targetDate);
      // Rough time calculation (this is simplified)
      eventStart.setMinutes(eventStart.getMinutes() - (schedule.length - index) * 30);

      const dtStart = eventStart.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
      const dtEnd = new Date(eventStart.getTime() + 30 * 60000).toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';

      icsContent += `BEGIN:VEVENT
DTSTART:${dtStart}
DTEND:${dtEnd}
SUMMARY:${item.task}
DESCRIPTION:Duration: ${item.duration}
END:VEVENT
`;
    });

    icsContent += 'END:VCALENDAR';

    // Download file
    const blob = new Blob([icsContent], { type: 'text/calendar' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `baking-schedule-${state.style}.ics`;
    a.click();
    URL.revokeObjectURL(url);

    showToast('Calendar file downloaded!');
  });

