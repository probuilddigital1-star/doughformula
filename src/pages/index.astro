  }

  const flourBlend: FlourEntry[] = [
    { type: 'bread', percent: 100 }
  ];

  // Get initial instructions from first style card
  const firstCard = document.querySelector('.style-card') as HTMLElement;
  if (firstCard) {
    state.instructions = JSON.parse(firstCard.dataset.instructions || '[]');
  }

  // Temperature conversion helpers
  function celsiusToFahrenheit(c: number): number {
    return Math.round((c * 9/5) + 32);
  }

  function fahrenheitToCelsius(f: number): number {
    return Math.round((f - 32) * 5/9);
  }

  function formatTemp(tempF: number): string {
    if (state.tempUnit === 'C') {
      return `${fahrenheitToCelsius(tempF)}°C`;
    }
    return `${tempF}°F`;
  }

  // Calculate water temperature using DDT formula
  function calculateWaterTemp(): number {
    // Formula: Water = (DDT × 3) - Room - Flour - Friction
    return (state.ddt * 3) - state.roomTemp - state.flourTemp - state.frictionFactor;
  }

  // Calculate starter contribution (flour and water from starter)
  function calculateStarterContribution(starterWeight: number): { flour: number; water: number } {
    // Starter hydration: 100% means equal flour and water
    // e.g., 100g starter at 100% = 50g flour + 50g water
    const starterFlour = Math.round(starterWeight / (1 + state.starterHydration / 100));
    const starterWater = starterWeight - starterFlour;
    return { flour: starterFlour, water: starterWater };
  }

  // Estimate fermentation times based on temperature and yeast type
  function estimateFermentationTimes(): { bulk: string; proof: string; total: string } {
    // Base times at 75°F (24°C)
    let baseBulkMin = 1.5; // hours
    let baseBulkMax = 2;
    let baseProofMin = 0.75;
    let baseProofMax = 1.5;

    // Adjust for yeast type
    if (state.yeastType === 'starter') {
      baseBulkMin = 4;
      baseBulkMax = 6;
      baseProofMin = 1;
      baseProofMax = 2;
    } else if (state.yeastPercent < 0.5) {
      // Low yeast (like no-knead)
      baseBulkMin = 12;
      baseBulkMax = 18;
    }

    // Temperature adjustment: ~10% change per degree F from 75°F
    const tempDiff = state.ddt - 75;
    const tempFactor = Math.pow(0.93, tempDiff / 5); // Warmer = faster

    const adjustedBulkMin = baseBulkMin * tempFactor;
    const adjustedBulkMax = baseBulkMax * tempFactor;
    const adjustedProofMin = baseProofMin * tempFactor;
    const adjustedProofMax = baseProofMax * tempFactor;

    // Format times
    const formatTime = (min: number, max: number): string => {
      if (min >= 1) {
        return `${min.toFixed(0)}-${max.toFixed(0)} hrs`;
      } else {
        return `${Math.round(min * 60)}-${Math.round(max * 60)} min`;
      }
    };

    const totalMin = adjustedBulkMin + adjustedProofMin;
    const totalMax = adjustedBulkMax + adjustedProofMax;

    return {
      bulk: formatTime(adjustedBulkMin, adjustedBulkMax),
      proof: formatTime(adjustedProofMin, adjustedProofMax),
      total: formatTime(totalMin, totalMax)
    };
  }

  // Calculate total whole grain percentage from flour blend
  function calculateWholeGrainPercent(): number {
    return flourBlend.reduce((total, flour) => {
      if (FLOUR_DATA[flour.type]?.wholeGrain) {
        return total + flour.percent;
      }
      return total;
    }, 0);
  }

  // Calculate preferment ingredients
  function calculatePrefermentIngredients(totalFlourWeight: number): { flour: number; water: number; yeast: number; yeastNote: string } | null {
    if (state.prefermentType === 'none') return null;

    const prefData = PREFERMENT_DATA[state.prefermentType];
    if (!prefData) return null;

    const prefFlour = Math.round(totalFlourWeight * state.prefermentPercent / 100);

    // Handle hydration
    let prefWater: number;
    if (prefData.hydration === -1) {
      // Pâte Fermentée uses recipe hydration
      prefWater = Math.round(prefFlour * state.hydration / 100);
    } else {
      prefWater = Math.round(prefFlour * prefData.hydration / 100);
    }

    // Handle yeast
    let prefYeast: number;
    let yeastNote: string;
    if (state.prefermentType === 'levain') {
      // Levain uses starter, not commercial yeast
      prefYeast = Math.round(prefFlour * 0.2); // 20% starter
      yeastNote = '(active starter)';
    } else if (prefData.yeastPercent === -1) {
      // Pâte Fermentée uses recipe yeast amount
      prefYeast = Math.round(prefFlour * state.yeastPercent / 100);
      yeastNote = '';
    } else {
      prefYeast = prefFlour * prefData.yeastPercent / 100;
      // Format tiny yeast amounts
      if (prefYeast < 1) {
        yeastNote = '(tiny pinch)';
        prefYeast = Math.round(prefYeast * 10) / 10; // Round to 1 decimal
      } else {
        yeastNote = '';
        prefYeast = Math.round(prefYeast);
      }
    }

    return { flour: prefFlour, water: prefWater, yeast: prefYeast, yeastNote };
  }

  // Estimate preferment timing based on room temperature
  function estimatePrefermentTiming(): { fermentTime: string; startTime: string } {
    if (state.prefermentType === 'none') {
      return { fermentTime: '-', startTime: '-' };
    }

    const prefData = PREFERMENT_DATA[state.prefermentType];
    if (!prefData) return { fermentTime: '-', startTime: '-' };

    // Adjust timing based on room temperature
    const tempDiff = state.roomTemp - 70; // Base temp 70°F
    const tempFactor = Math.pow(0.93, tempDiff / 5); // Warmer = faster

    const minTime = Math.round(prefData.fermentTimeMin * tempFactor);
    const maxTime = Math.round(prefData.fermentTimeMax * tempFactor);

    const fermentTime = `${minTime}-${maxTime} hrs`;

    // Calculate when to start (average of min/max from a 9am bake)
    const avgTime = (minTime + maxTime) / 2;
    let startTime: string;
    if (avgTime <= 4) {
      startTime = 'Early morning of bake day';
    } else if (avgTime <= 8) {
      startTime = 'Evening before bake day';
    } else if (avgTime <= 14) {
      startTime = 'Night before (before bed)';
    } else {
      startTime = 'Previous afternoon';
    }

    return { fermentTime, startTime };
  }

  // Generate baking schedule
  function generateBakingSchedule(targetDateTime: Date): Array<{ time: string; task: string; duration: string }> {
    const schedule: Array<{ time: string; task: string; duration: string }> = [];

    // Work backwards from target time
    let currentTime = new Date(targetDateTime);

    // Cooling time (1 hour)
    currentTime.setHours(currentTime.getHours() - 1);
    schedule.unshift({
      time: formatScheduleTime(currentTime),
      task: 'Cool on wire rack',
      duration: '1 hr'
    });

    // Baking time (depends on style, but average 45 min)
    currentTime.setMinutes(currentTime.getMinutes() - 45);
    schedule.unshift({
      time: formatScheduleTime(currentTime),
      task: 'Bake bread',
      duration: '35-45 min'
    });

    // Preheat (30-45 min for Dutch oven)
    currentTime.setMinutes(currentTime.getMinutes() - 45);
    schedule.unshift({
      time: formatScheduleTime(currentTime),
      task: 'Preheat oven (with Dutch oven)',
      duration: '45 min'
    });

    // Final proof
    const fermentTimes = estimateFermentationTimes();
    const proofHours = state.coldRetard ? 0.5 : 1.5; // If cold retard, just warmup
    currentTime.setMinutes(currentTime.getMinutes() - proofHours * 60);

    if (state.coldRetard) {
      schedule.unshift({
        time: formatScheduleTime(currentTime),
        task: 'Remove from fridge, let warm',
        duration: '30 min'
      });
      // Cold retard overnight
      const coldRetardTime = new Date(currentTime);
      coldRetardTime.setHours(coldRetardTime.getHours() - 12);
      schedule.unshift({
        time: formatScheduleTime(coldRetardTime),
        task: 'Shape & refrigerate overnight',
        duration: '8-12 hrs'
      });
      currentTime = coldRetardTime;
    } else {
      schedule.unshift({
        time: formatScheduleTime(currentTime),
        task: 'Shape and final proof',
        duration: fermentTimes.proof
      });
    }

    // Bulk fermentation
    const bulkHours = state.yeastType === 'starter' ? 5 : (state.yeastPercent < 0.5 ? 15 : 2);
    currentTime.setMinutes(currentTime.getMinutes() - bulkHours * 60);
    schedule.unshift({
      time: formatScheduleTime(currentTime),
      task: 'Bulk fermentation (stretch & fold)',
      duration: fermentTimes.bulk
    });

    // Autolyse (if enabled)
    if (state.autolyse) {
      currentTime.setMinutes(currentTime.getMinutes() - state.autolyseDuration);
      schedule.unshift({
        time: formatScheduleTime(currentTime),
        task: 'Autolyse (flour + water rest)',
        duration: `${state.autolyseDuration} min`
      });
    }

    // Mix dough
    currentTime.setMinutes(currentTime.getMinutes() - 15);
    schedule.unshift({
      time: formatScheduleTime(currentTime),
      task: 'Mix final dough',
      duration: '10-15 min'
    });

    // Preferment (if enabled)
    if (state.prefermentType !== 'none') {
      const prefTiming = estimatePrefermentTiming();
      const prefData = PREFERMENT_DATA[state.prefermentType];
      if (prefData) {
        const prefHours = (prefData.fermentTimeMin + prefData.fermentTimeMax) / 2;
        currentTime.setMinutes(currentTime.getMinutes() - prefHours * 60);
        schedule.unshift({
          time: formatScheduleTime(currentTime),
          task: `Mix ${prefData.name}`,
          duration: prefTiming.fermentTime
        });
      }
    }

    return schedule;
  }

  function formatScheduleTime(date: Date): string {
    return date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
  }

  // Calculate water contribution from enrichments
  function calculateEnrichmentWaterContribution(flourWeight: number): { totalWater: number; breakdown: string[] } {
    let totalWater = 0;
    const breakdown: string[] = [];

    // Fat contribution
    if (enrichmentState.fat.enabled) {
      const fatWeight = flourWeight * enrichmentState.fat.percent / 100;
      const waterFromFat = fatWeight * ENRICHMENT_WATER_CONTENT[enrichmentState.fat.type];
      totalWater += waterFromFat;
      if (waterFromFat > 0) {
        breakdown.push(`${enrichmentState.fat.type}: ${Math.round(waterFromFat)}g water`);
      }
    }

    // Egg contribution
    if (enrichmentState.eggs.enabled) {
      const eggWeight = enrichmentState.eggs.count * 50; // 50g per large egg
      const waterFromEggs = eggWeight * ENRICHMENT_WATER_CONTENT[enrichmentState.eggs.type];
      totalWater += waterFromEggs;
      breakdown.push(`Eggs: ${Math.round(waterFromEggs)}g water`);
    }

    // Dairy contribution (replaces portion of water)
    if (enrichmentState.dairy.enabled) {
      // Dairy replaces water, so the net water change is based on dairy water content
      // If using 50% milk at 87% water, and rest is 100% water, net effect is small
      const baseWater = flourWeight * state.hydration / 100;
      const dairyPortion = baseWater * enrichmentState.dairy.percentOfLiquid / 100;
      const waterFromDairy = dairyPortion * ENRICHMENT_WATER_CONTENT[enrichmentState.dairy.type];
      const waterReplaced = dairyPortion; // This was water
      const netChange = waterFromDairy - waterReplaced;
      totalWater += netChange;
      if (Math.abs(netChange) > 1) {
        breakdown.push(`Dairy: ${netChange > 0 ? '+' : ''}${Math.round(netChange)}g net`);
      }
    }

    // Sweetener contribution
    if (enrichmentState.sweet.enabled) {
      const sweetWeight = flourWeight * enrichmentState.sweet.percent / 100;
      const waterFromSweet = sweetWeight * ENRICHMENT_WATER_CONTENT[enrichmentState.sweet.type];
      totalWater += waterFromSweet;
      if (waterFromSweet > 0) {
        breakdown.push(`${enrichmentState.sweet.type}: ${Math.round(waterFromSweet)}g water`);
      }
    }

    return { totalWater, breakdown };
  }

  // Calculate effective hydration considering enrichments
  function calculateEffectiveHydration(flourWeight: number, baseWater: number): number {
    const { totalWater } = calculateEnrichmentWaterContribution(flourWeight);
    const effectiveWater = baseWater + totalWater;
    return Math.round((effectiveWater / flourWeight) * 100);
  }

  function calculateRecipe() {
    const totalDough = state.numLoaves * state.loafWeight;

    // Calculate base flour weight
    let yeastContribution = state.yeastPercent / 100;
    if (state.yeastType !== 'starter') {
      // Commercial yeast is much smaller percentage
      yeastContribution = state.yeastPercent / 100;
    }

    const flourWeight = Math.round(totalDough / (1 + state.hydration / 100 + state.salt / 100 + yeastContribution));
    let waterWeight = Math.round(flourWeight * state.hydration / 100);
    const saltWeight = Math.round(flourWeight * state.salt / 100);
    const yeastWeight = Math.round(flourWeight * state.yeastPercent / 100);

    // For starter, calculate flour/water contribution
    let starterFlourContrib = 0;
    let starterWaterContrib = 0;
    if (state.yeastType === 'starter') {
      const starterContrib = calculateStarterContribution(yeastWeight);
      starterFlourContrib = starterContrib.flour;
      starterWaterContrib = starterContrib.water;
    }

    // Calculate whole grain from flour blend
    const wholeGrainPercent = calculateWholeGrainPercent();
    const wholeGrainWeight = Math.round(flourWeight * wholeGrainPercent / 100);
    const whiteFlourWeight = flourWeight - wholeGrainWeight;

    // Calculate water temperature
    const calculatedWaterTemp = calculateWaterTemp();

    // Calculate enrichment contributions
    const enrichmentWater = calculateEnrichmentWaterContribution(flourWeight);
    const effectiveHydration = calculateEffectiveHydration(flourWeight, waterWeight);

    // Calculate enrichment weights
    const enrichments = {
      fat: enrichmentState.fat.enabled ? Math.round(flourWeight * enrichmentState.fat.percent / 100) : 0,
      eggs: enrichmentState.eggs.enabled ? enrichmentState.eggs.count * 50 : 0,
      sweet: enrichmentState.sweet.enabled ? Math.round(flourWeight * enrichmentState.sweet.percent / 100) : 0
    };

    return {
      totalDough,
      flourWeight,
      whiteFlourWeight,
      wholeGrainWeight,
      wholeGrainPercent,
      waterWeight,
      saltWeight,
      yeastWeight,
      starterFlourContrib,
      starterWaterContrib,
      calculatedWaterTemp,
      enrichmentWater,
      effectiveHydration,
      enrichments
    };
  }

  function convertToOz(grams: number): string {
    return (grams / 28.35).toFixed(1);
  }

  function formatWeight(grams: number): string {
    if (state.unit === 'oz') {
      return `${convertToOz(grams)}oz`;
    }
    return `${grams}g`;
  }

  function updateUI() {
    const recipe = calculateRecipe();

    // Update total weight display
    const totalWeightEl = document.getElementById('total-weight');
    if (totalWeightEl) {
      totalWeightEl.textContent = formatWeight(recipe.totalDough);
    }

    // Update recipe card title
    const titleEl = document.getElementById('recipe-title');
    if (titleEl) {
      const styleName = state.style.charAt(0).toUpperCase() + state.style.slice(1).replace('-', ' ');
      titleEl.textContent = `${styleName} Bread`;
    }

    // Update recipe yield
    const yieldEl = document.getElementById('recipe-yield');
    if (yieldEl) {
      yieldEl.textContent = `Makes ${state.numLoaves} ${state.numLoaves === 1 ? 'loaf' : 'loaves'} at ${formatWeight(state.loafWeight)} each (${formatWeight(recipe.totalDough)} total)`;
    }

    // Update preferment section visibility and content
    const prefermentSection = document.getElementById('preferment-section');
    const ingredientsHeading = document.getElementById('ingredients-heading-text');
    const prefIngredients = calculatePrefermentIngredients(recipe.flourWeight);

    if (prefermentSection && ingredientsHeading) {
      if (state.prefermentType !== 'none' && prefIngredients) {
        prefermentSection.classList.remove('hidden');
        ingredientsHeading.textContent = 'Final Dough';

        // Update preferment section details
        const prefData = PREFERMENT_DATA[state.prefermentType];
        const prefTitle = document.getElementById('preferment-title');
        const prefTimingBadge = document.getElementById('preferment-timing-badge');
        const prefReadySigns = document.getElementById('preferment-ready-signs');
        const prefIngList = document.getElementById('preferment-ingredients-list');

        if (prefTitle) prefTitle.textContent = prefData.name.toUpperCase();
        if (prefTimingBadge) prefTimingBadge.textContent = `Make ${prefData.fermentTimeMin}-${prefData.fermentTimeMax} hrs before`;
        if (prefReadySigns) prefReadySigns.textContent = prefData.readySigns;

        // Build preferment ingredients list
        if (prefIngList) {
          const prefIngs = [];
          prefIngs.push({ name: 'Bread Flour', weight: prefIngredients.flour, note: `(${state.prefermentPercent}% of total)` });
          prefIngs.push({ name: 'Water', weight: prefIngredients.water, note: prefData.hydration === -1 ? '(recipe hydration)' : `(${prefData.hydration}% hydration)` });

          if (state.prefermentType === 'levain') {
            prefIngs.push({ name: 'Active Starter', weight: prefIngredients.yeast, note: prefIngredients.yeastNote });
          } else if (prefIngredients.yeast > 0) {
            prefIngs.push({ name: 'Instant Yeast', weight: prefIngredients.yeast, note: prefIngredients.yeastNote });
          }

          prefIngList.innerHTML = prefIngs.map(ing => `
            <div class="flex justify-between py-1.5 border-b border-[var(--border-light)] last:border-0">
              <span class="font-medium">${ing.name}</span>
              <span class="flex gap-2">
                <span>${typeof ing.weight === 'number' && ing.weight < 1 ? ing.weight.toFixed(1) : Math.round(ing.weight)}g</span>
                ${ing.note ? `<span class="text-xs text-[var(--crust-brown)]">${ing.note}</span>` : ''}
              </span>
            </div>
          `).join('');
        }
      } else {
        prefermentSection.classList.add('hidden');
        ingredientsHeading.textContent = 'Ingredients';
      }
    }

    // Update ingredients list (Final Dough when preferment active)
    const ingredientsList = document.getElementById('ingredients-list');
    if (ingredientsList) {
      const ingredients = [];

      // Calculate remaining flour and water after preferment
      let finalFlour = recipe.flourWeight;
      let finalWater = recipe.waterWeight;

      if (state.prefermentType !== 'none' && prefIngredients) {
        finalFlour = recipe.flourWeight - prefIngredients.flour;
        finalWater = recipe.waterWeight - prefIngredients.water;
      }

      if (state.wholeGrain > 0) {
        // When using preferment, apply percentage to final flour
        const whiteFlourFinal = Math.round(finalFlour * (100 - state.wholeGrain) / 100);
        const wholeGrainFinal = finalFlour - whiteFlourFinal;
        ingredients.push({
          name: 'Bread Flour',
          weight: whiteFlourFinal,
          percent: 100 - state.wholeGrain,
          note: state.prefermentType !== 'none' ? '(remaining)' : ''
        });
        ingredients.push({
          name: 'Whole Wheat Flour',
          weight: wholeGrainFinal,
          percent: state.wholeGrain,
          note: ''
        });
      } else {
        ingredients.push({
          name: 'Flour',
          weight: finalFlour,
          percent: 100,
          note: state.prefermentType !== 'none' ? '(remaining)' : ''
        });
      }

      ingredients.push({
        name: 'Water',
        weight: finalWater,
        percent: state.hydration,
        note: state.prefermentType !== 'none' ? '(adjust for preferment)' : ''
      });

      ingredients.push({
        name: 'Salt',
        weight: recipe.saltWeight,
        percent: state.salt,
        note: ''
      });

      // Add preferment as ingredient if active
      if (state.prefermentType !== 'none' && prefIngredients) {
        const prefData = PREFERMENT_DATA[state.prefermentType];
        ingredients.push({
          name: `All of the ${prefData.name}`,
          weight: prefIngredients.flour + prefIngredients.water,
          percent: -1, // Special marker for no percentage
          note: ''
        });
      } else {
        // Yeast/Starter with appropriate naming (only when no preferment)
        const yeastNames: Record<string, string> = {
          'starter': 'Sourdough Starter',
          'instant': 'Instant Yeast',
          'active-dry': 'Active Dry Yeast',
          'fresh': 'Fresh Yeast'
        };
        ingredients.push({
          name: yeastNames[state.yeastType] || 'Yeast',
          weight: recipe.yeastWeight,
          percent: state.yeastPercent,
          note: ''
        });
      }

      // Add enrichments if enabled
      if (enrichmentState.fat.enabled) {
        const fatName = enrichmentState.fat.type === 'butter' ? 'Butter' : 'Oil';
        ingredients.push({
          name: fatName,
          weight: recipe.enrichments.fat,
          percent: enrichmentState.fat.percent,
          note: ''
        });
      }

      if (enrichmentState.eggs.enabled) {
        const eggName = enrichmentState.eggs.type === 'whole' ? 'Eggs' :
                       enrichmentState.eggs.type === 'yolks' ? 'Egg Yolks' : 'Egg Whites';
        ingredients.push({
          name: `${eggName} (${enrichmentState.eggs.count})`,
          weight: recipe.enrichments.eggs,
          percent: Math.round((recipe.enrichments.eggs / recipe.flourWeight) * 100),
          note: ''
        });
      }

      if (enrichmentState.sweet.enabled) {
        const sweetName = enrichmentState.sweet.type.charAt(0).toUpperCase() + enrichmentState.sweet.type.slice(1);
        ingredients.push({
          name: sweetName,
          weight: recipe.enrichments.sweet,
          percent: enrichmentState.sweet.percent,
          note: ''
        });
      }

      ingredientsList.innerHTML = ingredients.map(ing => `
        <div class="flex justify-between py-2 border-b border-[var(--border-light)]">
          <span>${ing.name}${ing.note ? ` <span class="text-xs text-[var(--crust-brown)]">${ing.note}</span>` : ''}</span>
          <span class="flex gap-4">
            <span class="font-medium">${formatWeight(ing.weight)}</span>
            ${ing.percent >= 0 ? `<span class="text-[var(--crust-brown)] w-16 text-right">(${ing.percent}%)</span>` : '<span class="w-16"></span>'}
          </span>
        </div>
      `).join('');
    }

    // Update tips - now show calculated water temperature
    const waterTempEl = document.getElementById('water-temp');
    if (waterTempEl) {
      const calcTemp = recipe.calculatedWaterTemp;
      if (calcTemp < 40 || calcTemp > 110) {
        waterTempEl.textContent = `${formatTemp(calcTemp)} (adjust needed)`;
      } else {
        waterTempEl.textContent = formatTemp(calcTemp);
      }
    }

    const flourRecEl = document.getElementById('flour-rec');
    if (flourRecEl) {
      flourRecEl.textContent = state.flour;
    }

    // Update instructions
    const instructionsList = document.getElementById('instructions-list');
    if (instructionsList && state.instructions.length > 0) {
      instructionsList.innerHTML = state.instructions.map((inst, i) => `
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 rounded-full bg-[var(--accent-gold)] text-white text-sm flex items-center justify-center">${i + 1}</span>
          <span class="text-[var(--crust-brown)]">${inst}</span>
        </li>
      `).join('');
    }

    // Update slider displays - Basics tab
    const hydrationValue = document.getElementById('hydration-value');
    if (hydrationValue) hydrationValue.textContent = `${state.hydration}%`;

    const wholeGrainValue = document.getElementById('whole-grain-value');
    if (wholeGrainValue) wholeGrainValue.textContent = `${state.wholeGrain}%`;

    const saltValue = document.getElementById('salt-value');
    if (saltValue) saltValue.textContent = `${state.salt}%`;

    // Update Yeast tab
    const yeastPercentValue = document.getElementById('yeast-percent-value');
    if (yeastPercentValue) yeastPercentValue.textContent = `${state.yeastPercent}%`;

    const yeastPercentLabel = document.getElementById('yeast-percent-label');
    if (yeastPercentLabel) {
      yeastPercentLabel.textContent = state.yeastType === 'starter' ? 'Starter Amount' : 'Yeast Amount';
    }

    // Update yeast percent slider range based on type
    const yeastPercentSlider = document.getElementById('yeast-percent-slider') as HTMLInputElement;
    if (yeastPercentSlider) {
      if (state.yeastType === 'starter') {
        yeastPercentSlider.min = '10';
        yeastPercentSlider.max = '40';
        yeastPercentSlider.step = '1';
      } else {
        yeastPercentSlider.min = '0.1';
        yeastPercentSlider.max = '3';
        yeastPercentSlider.step = '0.1';
      }
      yeastPercentSlider.value = String(state.yeastPercent);
    }

    // Show/hide starter-specific controls
    const starterHydrationControl = document.getElementById('starter-hydration-control');
    const starterContributionEl = document.getElementById('starter-contribution');
    if (starterHydrationControl && starterContributionEl) {
      if (state.yeastType === 'starter') {
        starterHydrationControl.classList.remove('hidden');
        starterContributionEl.classList.remove('hidden');
        // Update starter contribution display
        const flourContrib = document.getElementById('starter-flour-contrib');
        const waterContrib = document.getElementById('starter-water-contrib');
        if (flourContrib) flourContrib.textContent = `${recipe.starterFlourContrib}g`;
        if (waterContrib) waterContrib.textContent = `${recipe.starterWaterContrib}g`;
      } else {
        starterHydrationControl.classList.add('hidden');
        starterContributionEl.classList.add('hidden');
      }
    }

    const starterHydrationValue = document.getElementById('starter-hydration-value');
    if (starterHydrationValue) starterHydrationValue.textContent = `${state.starterHydration}%`;

    // Update yeast tip
    const yeastTipText = document.getElementById('yeast-tip-text');
    if (yeastTipText) {
      yeastTipText.textContent = YEAST_TIPS[state.yeastType] || YEAST_TIPS['instant'];
    }

    // Update Temperature tab
    const ddtValue = document.getElementById('ddt-value');
    if (ddtValue) ddtValue.textContent = formatTemp(state.ddt);

    const roomTempValue = document.getElementById('room-temp-value');
    if (roomTempValue) roomTempValue.textContent = formatTemp(state.roomTemp);

    const flourTempValue = document.getElementById('flour-temp-value');
    if (flourTempValue) flourTempValue.textContent = formatTemp(state.flourTemp);

    const frictionValue = document.getElementById('friction-value');
    if (frictionValue) frictionValue.textContent = formatTemp(state.frictionFactor).replace('°', '°');

    // Update calculated water temperature
    const calcWaterTemp = document.getElementById('calc-water-temp');
    if (calcWaterTemp) {
      calcWaterTemp.textContent = formatTemp(recipe.calculatedWaterTemp);
    }

    // Update water temp formula display
    const waterTempFormula = document.getElementById('water-temp-formula');
    if (waterTempFormula) {
      const unit = state.tempUnit === 'C' ? '°C' : '°F';
      const ddt = state.tempUnit === 'C' ? fahrenheitToCelsius(state.ddt) : state.ddt;
      const room = state.tempUnit === 'C' ? fahrenheitToCelsius(state.roomTemp) : state.roomTemp;
      const flour = state.tempUnit === 'C' ? fahrenheitToCelsius(state.flourTemp) : state.flourTemp;
      const friction = state.tempUnit === 'C' ? fahrenheitToCelsius(state.frictionFactor) : state.frictionFactor;
      const result = state.tempUnit === 'C' ? fahrenheitToCelsius(recipe.calculatedWaterTemp) : recipe.calculatedWaterTemp;
      waterTempFormula.textContent = `(${ddt} × 3) - ${room} - ${flour} - ${friction} = ${result}${unit}`;
    }

    // Show/hide water temp warning
    const waterTempWarning = document.getElementById('water-temp-warning');
    if (waterTempWarning) {
      if (recipe.calculatedWaterTemp < 40) {
        waterTempWarning.textContent = '⚠️ Water too cold! Add ice or use cold water.';
        waterTempWarning.classList.remove('hidden');
      } else if (recipe.calculatedWaterTemp > 110) {
        waterTempWarning.textContent = '⚠️ Water too hot! May kill yeast. Cool your environment.';
        waterTempWarning.classList.remove('hidden');
      } else {
        waterTempWarning.classList.add('hidden');
      }
    }

    // Update Timing tab
    const fermentTimes = estimateFermentationTimes();

    const bulkTime = document.getElementById('bulk-time');
    if (bulkTime) bulkTime.textContent = fermentTimes.bulk;

    const proofTime = document.getElementById('proof-time');
    if (proofTime) proofTime.textContent = fermentTimes.proof;

    const totalTime = document.getElementById('total-time');
    if (totalTime) totalTime.textContent = fermentTimes.total;

    // Update timing descriptions based on yeast type
    const bulkDescription = document.getElementById('bulk-description');
    if (bulkDescription) {
      if (state.yeastType === 'starter') {
        bulkDescription.textContent = 'Look for 50-75% rise with visible bubbles. Dough should be airy and jiggly.';
      } else if (state.yeastPercent < 0.5) {
        bulkDescription.textContent = 'Long, slow ferment develops flavor. Dough should be bubbly and doubled.';
      } else {
        bulkDescription.textContent = 'Look for doubled volume with a domed surface.';
      }
    }

    const proofDescription = document.getElementById('proof-description');
    if (proofDescription) {
      if (state.coldRetard) {
        proofDescription.textContent = 'Cold proof in refrigerator. Bake straight from cold or let warm 30 min.';
      } else {
        proofDescription.textContent = 'Poke test: dough should spring back slowly but not completely.';
      }
    }

    // Update total time note
    const totalTimeNote = document.getElementById('total-time-note');
    if (totalTimeNote) {
      if (state.coldRetard) {
        totalTimeNote.textContent = 'Plus 8-18 hours cold retard in refrigerator';
