---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/hero-bread.jpg';

// Bread style icons (SVG paths)
const icons = {
  sourdough: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="16" cy="18" rx="12" ry="8"/><path d="M8 14c2-4 6-6 8-6s6 2 8 6"/><path d="M12 18c1-2 3-3 4-3s3 1 4 3"/></svg>`,
  baguette: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22c-1-2-1-4 0-6 2-4 8-8 14-10 2 0 4 1 5 3 1 2 1 5-1 7-3 4-10 8-16 9-1 0-2-1-2-3z"/><path d="M10 16l3-3M14 18l3-3M18 14l2-2"/></svg>`,
  focaccia: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="10" width="22" height="14" rx="3"/><circle cx="10" cy="17" r="1.5"/><circle cx="16" cy="14" r="1.5"/><circle cx="22" cy="17" r="1.5"/><circle cx="13" cy="20" r="1.5"/><circle cx="19" cy="20" r="1.5"/></svg>`,
  sandwich: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="8" width="18" height="16" rx="4"/><path d="M7 16h18"/><path d="M10 12h2M14 12h2"/></svg>`,
  ciabatta: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 18c0-3 2-6 6-7h12c4 1 6 4 6 7s-2 5-5 6H9c-3-1-5-3-5-6z"/><circle cx="11" cy="16" r="1"/><circle cx="16" cy="18" r="1.5"/><circle cx="21" cy="15" r="1"/><circle cx="14" cy="14" r="0.75"/></svg>`,
  brioche: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="16" cy="10" r="5"/><ellipse cx="16" cy="21" rx="8" ry="6"/><path d="M12 15c0 1 2 2 4 2s4-1 4-2"/></svg>`,
  noknead: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="16" cy="16" r="11"/><path d="M16 8v8l5 3"/></svg>`,
  custom: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="16" cy="16" r="3"/><path d="M16 6v3M16 23v3M6 16h3M23 16h3"/><path d="M9.5 9.5l2 2M20.5 20.5l2 2M9.5 22.5l2-2M20.5 11.5l2-2"/></svg>`
};

// Bread style data
const breadStyles = [
  {
    id: 'sourdough',
    name: 'Sourdough',
    description: 'Wild yeast, complex tang, overnight fermentation',
    icon: icons.sourdough,
    hydration: 75,
    salt: 2,
    yeastType: 'starter',
    yeastPercent: 20,
    wholeGrain: 10,
    flour: 'Bread Flour + Whole Wheat',
    waterTemp: '78-82°F / 26-28°C',
    instructions: [
      'Mix flour and water, autolyse 30-60 minutes',
      'Add starter and salt, mix until combined',
      'Stretch and fold every 30 min for 2 hours',
      'Bulk ferment 4-6 hours at room temperature',
      'Shape and proof overnight in refrigerator (8-12 hrs)',
      'Bake in Dutch oven at 500°F for 20 min covered, 25 min uncovered'
    ]
  },
  {
    id: 'baguette',
    name: 'Baguette',
    description: 'Crisp crust, open crumb, classic French',
    icon: icons.baguette,
    hydration: 68,
    salt: 2,
    yeastType: 'instant',
    yeastPercent: 0.5,
    wholeGrain: 0,
    flour: 'Bread Flour or T65',
    waterTemp: '75-78°F / 24-26°C',
    instructions: [
      'Mix flour, water, yeast. Autolyse 20 minutes',
      'Add salt, mix until smooth',
      'Fold every 30 minutes for 1.5 hours',
      'Bulk ferment 2-3 hours until doubled',
      'Divide and pre-shape, rest 20 minutes',
      'Final shape into baguettes, proof 45-60 minutes',
      'Score and bake at 475°F with steam for 22-25 minutes'
    ]
  },
  {
    id: 'focaccia',
    name: 'Focaccia',
    description: 'Olive oil enriched, dimpled, herbaceous',
    icon: icons.focaccia,
    hydration: 80,
    salt: 2.2,
    yeastType: 'instant',
    yeastPercent: 0.8,
    wholeGrain: 0,
    flour: 'Bread Flour or All-Purpose',
    waterTemp: '80-85°F / 27-29°C',
    instructions: [
      'Mix flour, water, yeast, and 2 tbsp olive oil',
      'Add salt, mix until smooth and elastic',
      'Stretch and fold every 30 min for 1.5 hours',
      'Pour into oiled pan, dimple with fingers',
      'Proof 1-2 hours until puffy',
      'Dimple again, drizzle olive oil, add toppings',
      'Bake at 425°F for 20-25 minutes until golden'
    ]
  },
  {
    id: 'sandwich',
    name: 'Sandwich Loaf',
    description: 'Soft, tender crumb for everyday slicing',
    icon: icons.sandwich,
    hydration: 62,
    salt: 1.8,
    yeastType: 'instant',
    yeastPercent: 1,
    wholeGrain: 0,
    flour: 'Bread Flour or All-Purpose',
    waterTemp: '95-105°F / 35-40°C',
    instructions: [
      'Dissolve yeast in warm water, let bloom 5 minutes',
      'Mix flour, salt, and 2 tbsp butter or oil',
      'Add yeast mixture, knead 8-10 minutes',
      'Bulk ferment 1-1.5 hours until doubled',
      'Shape into loaf, place in greased pan',
      'Proof 45-60 minutes until risen above pan',
      'Bake at 375°F for 30-35 minutes'
    ]
  },
  {
    id: 'ciabatta',
    name: 'Ciabatta',
    description: 'High hydration, irregular holes, rustic',
    icon: icons.ciabatta,
    hydration: 82,
    salt: 2,
    yeastType: 'instant',
    yeastPercent: 0.6,
    wholeGrain: 0,
    flour: 'Bread Flour',
    waterTemp: '70-75°F / 21-24°C',
    instructions: [
      'Mix flour, water, yeast into shaggy dough',
      'Rest 30 minutes (autolyse)',
      'Add salt, fold until incorporated',
      'Stretch and fold every 30 min for 3 hours',
      'Bulk ferment 2-3 hours until very bubbly',
      'Gently turn out, divide without degassing',
      'Proof 30-45 min, bake at 475°F with steam for 20-25 min'
    ]
  },
  {
    id: 'brioche',
    name: 'Brioche',
    description: 'Butter and eggs for rich, tender bread',
    icon: icons.brioche,
    hydration: 55,
    salt: 1.8,
    yeastType: 'instant',
    yeastPercent: 1.2,
    wholeGrain: 0,
    flour: 'All-Purpose Flour',
    waterTemp: '80-85°F / 27-29°C',
    instructions: [
      'Mix flour, sugar (8%), eggs, milk, and yeast',
      'Knead until smooth, about 10 minutes',
      'Gradually add soft butter (25%), knead until silky',
      'Add salt, knead 2 more minutes',
      'Bulk ferment 2 hours, then refrigerate overnight',
      'Shape cold dough, proof 2-3 hours until doubled',
      'Egg wash and bake at 350°F for 25-30 minutes'
    ]
  },
  {
    id: 'no-knead',
    name: 'No-Knead',
    description: 'Hands-off, long ferment, crispy crust',
    icon: icons.noknead,
    hydration: 78,
    salt: 2,
    yeastType: 'instant',
    yeastPercent: 0.25,
    wholeGrain: 0,
    flour: 'Bread Flour or All-Purpose',
    waterTemp: '70-75°F / 21-24°C',
    instructions: [
      'Mix flour, water, salt, and yeast until shaggy (2 min)',
      'Cover and let rise at room temperature 12-18 hours',
      'Dough is ready when bubbly and doubled',
      'Turn out onto floured surface, fold into ball',
      'Let rest 15 min, then shape into round',
      'Proof in bowl lined with floured towel 1-2 hours',
      'Preheat Dutch oven at 450°F for 30 min',
      'Bake covered 30 min, uncovered 15-20 min until deep golden'
    ]
  },
  {
    id: 'custom',
    name: 'Custom',
    description: 'Your recipe, your rules',
    icon: icons.custom,
    hydration: 70,
    salt: 2,
    yeastType: 'instant',
    yeastPercent: 1,
    wholeGrain: 0,
    flour: 'Your choice',
    waterTemp: 'Varies',
    instructions: [
      'Mix ingredients according to your method',
      'Knead or fold as needed',
      'Ferment according to your schedule',
      'Shape and proof',
      'Bake at appropriate temperature'
    ]
  }
];
---

<Layout>
  <main id="main-content">
  <nav class="sticky top-0 z-50 bg-[var(--cream-flour)]/95 backdrop-blur-sm border-b border-[var(--border-light)]">
    <div class="container flex items-center justify-between py-4">
      <a href="/" class="flex items-center gap-2">
        <svg class="w-7 h-7 text-[var(--accent-gold)]" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 28V12"/>
          <path d="M16 12c-2-3-2-6 0-8 2 2 2 5 0 8z"/>
          <path d="M16 16c-3-2-5-1-7 1 2 2 5 2 7-1z"/>
          <path d="M16 16c3-2 5-1 7 1-2 2-5 2-7-1z"/>
          <path d="M16 20c-3-2-5-1-7 1 2 2 5 2 7-1z"/>
          <path d="M16 20c3-2 5-1 7 1-2 2-5 2-7-1z"/>
          <path d="M16 24c-3-2-5-1-7 1 2 2 5 2 7-1z"/>
          <path d="M16 24c3-2 5-1 7 1-2 2-5 2-7-1z"/>
        </svg>
        <span class="font-display text-xl font-semibold">
          The Dough <span class="text-[var(--accent-gold)]">Formula</span>
        </span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#calculator" class="text-[var(--accent-gold)] font-medium">Calculator</a>
        <a href="#bread-styles" class="text-[var(--crust-brown)] hover:text-[var(--espresso)] transition-colors">Bread Styles</a>
        <a href="#bakers-percent" class="text-[var(--crust-brown)] hover:text-[var(--espresso)] transition-colors">Baker's %</a>
        <a href="#about" class="text-[var(--crust-brown)] hover:text-[var(--espresso)] transition-colors">About</a>
      </div>
      <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed inset-0 z-40 bg-[var(--cream-flour)] transform translate-x-full transition-transform md:hidden">
    <div class="flex flex-col items-center justify-center h-full gap-8 text-xl">
      <a href="#calculator" class="text-[var(--accent-gold)] font-medium mobile-menu-link">Calculator</a>
      <a href="#bread-styles" class="text-[var(--crust-brown)] mobile-menu-link">Bread Styles</a>
      <a href="#bakers-percent" class="text-[var(--crust-brown)] mobile-menu-link">Baker's %</a>
      <a href="#about" class="text-[var(--crust-brown)] mobile-menu-link">About</a>
      <button id="mobile-menu-close" class="mt-8 btn btn-outline">Close</button>
    </div>
  </div>

  <!-- Hero Section - Full Bleed Editorial -->
  <section class="hero-editorial">
    <!-- Background Image with Ken Burns -->
    <div class="hero-bg-image">
      <Image
        src={heroImage}
        alt="Freshly baked artisan sourdough bread with beautiful open crumb, sliced and displayed with rosemary"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width={1920}
        height={1280}
        quality={80}
        format="webp"
      />
    </div>

    <!-- Content Overlay -->
    <div class="hero-content container">
      <div class="max-w-2xl">
        <p class="animate-rise delay-1 text-sm tracking-[0.25em] text-[var(--accent-gold)] font-medium mb-6 flex items-center gap-4">
          <span class="w-12 h-px bg-[var(--accent-gold)]"></span>
          FOR HOME BAKERS
        </p>
        <h1 class="animate-rise delay-2 font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-medium mb-2 leading-[0.9]">
          The Art of
        </h1>
        <p class="animate-rise delay-3 font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-medium italic text-[var(--accent-gold)] mb-8 leading-[0.9]">
          Perfect Bread
        </p>
        <p class="animate-rise delay-4 font-editorial text-xl md:text-2xl text-[var(--crust-brown)] max-w-lg mb-10 leading-relaxed">
          Master baker's percentages. Calculate precise recipes for sourdough, baguettes, focaccia, and beyond.
        </p>
        <a href="#calculator" class="animate-rise delay-5 btn btn-primary text-lg px-8 py-4 inline-flex">
          Begin Your Bake
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="scroll-indicator hidden md:flex">
      <span>Scroll</span>
    </div>
  </section>

  <!-- Transition Divider -->
  <div class="py-8 scoring-divider">╱ ╱ ╱</div>

  <!-- Calculator Section -->
  <section id="calculator" class="py-12 md:py-20">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">

        <!-- Left Column: Style Selection & Quantity -->
        <div class="space-y-8">
          <!-- Bread Styles -->
          <div id="bread-styles">
            <h2 class="text-2xl font-display mb-2">Choose Your Style</h2>
            <p class="text-[var(--crust-brown)] mb-6">Select a style for recommended settings, or go custom.</p>

            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3" id="style-grid">
              {breadStyles.map((style, index) => (
                <button
                  class={`card p-4 text-left cursor-pointer hover:shadow-md transition-all style-card ${index === 0 ? 'card-selected' : ''}`}
                  data-style={style.id}
                  data-hydration={style.hydration}
                  data-salt={style.salt}
                  data-yeast-type={style.yeastType}
                  data-yeast-percent={style.yeastPercent}
                  data-whole-grain={style.wholeGrain}
                  data-flour={style.flour}
                  data-water-temp={style.waterTemp}
                  data-instructions={JSON.stringify(style.instructions)}
                >
                  <span class="w-8 h-8 mb-2 block text-[var(--accent-gold)]" set:html={style.icon}></span>
                  <span class="font-medium block">{style.name}</span>
                  <span class="text-sm text-[var(--crust-brown)] block mt-1">{style.description}</span>
                </button>
              ))}
            </div>

            <!-- Pizza Dough CTA -->
            <div class="pizza-cta mt-6" id="pizza-cta">
              <a href="https://thepizzadoughformula.com" target="_blank" rel="noopener" class="pizza-cta-link group">
                <div class="pizza-cta-content">
                  <div class="pizza-cta-icon">
                    <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                      <circle cx="16" cy="16" r="12"/>
                      <path d="M16 4v24M4 16h24"/>
                      <circle cx="11" cy="11" r="1.5" fill="currentColor"/>
                      <circle cx="20" cy="13" r="1" fill="currentColor"/>
                      <circle cx="13" cy="19" r="1.5" fill="currentColor"/>
                      <circle cx="19" cy="20" r="1" fill="currentColor"/>
                    </svg>
                  </div>
                  <div class="pizza-cta-text">
                    <span class="pizza-cta-label">Making Pizza?</span>
                    <span class="pizza-cta-headline">Discover <em>The Pizza Dough Formula</em></span>
                    <span class="pizza-cta-subtext">Neapolitan, New York, Detroit & more — precision-crafted for the perfect pie</span>
                  </div>
                  <div class="pizza-cta-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 transition-transform group-hover:translate-x-1">
                      <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
                    </svg>
                  </div>
                </div>
              </a>
            </div>
          </div>

          <!-- Dough Quantity -->
          <div class="card p-4 sm:p-6">
            <h3 class="text-lg font-display mb-4">Dough Quantity</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 mb-4">
              <div>
                <label for="num-loaves" class="block text-sm text-[var(--crust-brown)] mb-2">Number of Loaves</label>
                <div class="flex items-center gap-2">
                  <input
                    type="number"
                    id="num-loaves"
                    value="2"
                    min="1"
                    max="12"
                    class="input input-number"
                    aria-label="Number of loaves"
                  />
                  <span class="text-[var(--crust-brown)]" aria-hidden="true">loaves</span>
                </div>
              </div>
              <div>
                <label for="loaf-weight" class="block text-sm text-[var(--crust-brown)] mb-2">Weight per Loaf</label>
                <div class="flex items-center gap-2">
                  <input
                    type="number"
                    id="loaf-weight"
                    value="900"
                    min="200"
                    max="2000"
                    step="50"
                    class="input input-number"
                    aria-label="Weight per loaf in grams"
                  />
                  <span class="text-[var(--crust-brown)]" aria-hidden="true">g</span>
                </div>
              </div>
            </div>

            <div class="flex items-center justify-between py-3 px-4 bg-[var(--cream-warm)] rounded-lg mb-4">
              <span class="text-[var(--crust-brown)]">Total Dough Weight:</span>
              <span class="text-xl font-semibold text-[var(--accent-gold)]" id="total-weight">1800g</span>
            </div>

            <div class="flex flex-wrap gap-2">
              <span class="text-sm text-[var(--crust-brown)]">Quick presets:</span>
              <button class="preset-pill" data-loaves="1" data-weight="500">1 loaf</button>
              <button class="preset-pill preset-pill-active" data-loaves="2" data-weight="900">2 loaves</button>
              <button class="preset-pill" data-loaves="4" data-weight="900">4 loaves</button>
            </div>
          </div>

          <!-- Advanced Options - Tabbed Interface -->
          <div class="card p-0">
            <div class="accordion-item border-0">
              <button class="accordion-trigger px-4 sm:px-6 py-4" id="advanced-trigger">
                <span class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
                  </svg>
                  Advanced Options
                </span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform" id="advanced-chevron" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </button>
              <div class="hidden" id="advanced-content">
                <!-- Tab Navigation - Wrapping Grid -->
                <div class="advanced-tabs-grid" id="tabs-wrapper">
                    <button class="advanced-tab advanced-tab-active" data-tab="basics">Basics</button>
                    <button class="advanced-tab" data-tab="yeast">Yeast</button>
                    <button class="advanced-tab" data-tab="flour">Flour</button>
                    <button class="advanced-tab" data-tab="enrichments">Enrichments</button>
                    <button class="advanced-tab" data-tab="temperature">Temperature</button>
                    <button class="advanced-tab" data-tab="timing">Timing</button>
                    <button class="advanced-tab" data-tab="preferments">Preferments</button>
                </div>

                <!-- Tab: Basics -->
                <div class="advanced-tab-content p-4 sm:p-6 space-y-4" id="tab-basics">
                  <div>
                    <label for="hydration-slider" class="flex justify-between text-sm mb-2">
                      <span>Hydration</span>
                      <span class="font-medium" id="hydration-value">75%</span>
                    </label>
                    <input type="range" id="hydration-slider" min="55" max="90" value="75" class="w-full accent-[var(--accent-gold)]" aria-label="Hydration percentage" />
                  </div>
                  <div>
                    <label for="whole-grain-slider" class="flex justify-between text-sm mb-2">
                      <span>Whole Grain</span>
                      <span class="font-medium" id="whole-grain-value">10%</span>
                    </label>
                    <input type="range" id="whole-grain-slider" min="0" max="50" value="10" class="w-full accent-[var(--accent-gold)]" aria-label="Whole grain percentage" />
                  </div>
                  <div>
                    <label for="salt-slider" class="flex justify-between text-sm mb-2">
                      <span>Salt</span>
                      <span class="font-medium" id="salt-value">2%</span>
                    </label>
                    <input type="range" id="salt-slider" min="1.5" max="3" value="2" step="0.1" class="w-full accent-[var(--accent-gold)]" aria-label="Salt percentage" />
                  </div>
                </div>

                <!-- Tab: Yeast -->
                <div class="advanced-tab-content hidden p-4 sm:p-6 space-y-4" id="tab-yeast">
                  <div>
                    <label class="block text-sm mb-2">Yeast Type</label>
                    <div class="grid grid-cols-2 gap-2" id="yeast-type-selector">
                      <button class="yeast-type-btn yeast-type-active" data-yeast="starter">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                          <circle cx="12" cy="12" r="8"/>
