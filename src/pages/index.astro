    enrichmentState.eggs.count = parseInt((e.target as HTMLInputElement).value) || 2;
    const weightEl = document.getElementById('egg-weight');
    if (weightEl) {
      weightEl.textContent = String(enrichmentState.eggs.count * 50);
    }
    updateEnrichmentDisplay();
    updateUI();
  });

  // Dairy toggle
  document.getElementById('enrichment-dairy-toggle')?.addEventListener('change', (e) => {
    enrichmentState.dairy.enabled = (e.target as HTMLInputElement).checked;
    const controls = document.getElementById('dairy-controls');
    if (controls) {
      controls.classList.toggle('hidden', !enrichmentState.dairy.enabled);
    }
    updateEnrichmentDisplay();
    updateUI();
  });

  document.getElementById('dairy-type-select')?.addEventListener('change', (e) => {
    enrichmentState.dairy.type = (e.target as HTMLSelectElement).value;
    updateEnrichmentDisplay();
    updateUI();
  });

  document.getElementById('dairy-percent')?.addEventListener('input', (e) => {
    enrichmentState.dairy.percentOfLiquid = parseInt((e.target as HTMLInputElement).value) || 50;
    updateEnrichmentDisplay();
    updateUI();
  });

  // Sweetener toggle
  document.getElementById('enrichment-sweet-toggle')?.addEventListener('change', (e) => {
    enrichmentState.sweet.enabled = (e.target as HTMLInputElement).checked;
    const controls = document.getElementById('sweet-controls');
    if (controls) {
      controls.classList.toggle('hidden', !enrichmentState.sweet.enabled);
    }
    updateEnrichmentDisplay();
    updateUI();
  });

  document.getElementById('sweet-type-select')?.addEventListener('change', (e) => {
    enrichmentState.sweet.type = (e.target as HTMLSelectElement).value;
    updateEnrichmentDisplay();
    updateUI();
  });

  document.getElementById('sweet-percent')?.addEventListener('input', (e) => {
    enrichmentState.sweet.percent = parseFloat((e.target as HTMLInputElement).value) || 5;
    updateEnrichmentDisplay();
    updateUI();
  });

  // Update enrichment display
  function updateEnrichmentDisplay() {
    const hasEnrichments = enrichmentState.fat.enabled || enrichmentState.eggs.enabled ||
                          enrichmentState.dairy.enabled || enrichmentState.sweet.enabled;

    const displayEl = document.getElementById('effective-hydration-display');
    if (displayEl) {
      displayEl.classList.toggle('hidden', !hasEnrichments);
    }

    if (hasEnrichments) {
      const recipe = calculateRecipe();
      const effectiveHydrationEl = document.getElementById('effective-hydration');
      if (effectiveHydrationEl) {
        effectiveHydrationEl.textContent = `${recipe.effectiveHydration}%`;
      }

      const targetHydrationEl = document.getElementById('target-hydration');
      if (targetHydrationEl) {
        targetHydrationEl.textContent = String(state.hydration);
      }

      const breakdownEl = document.getElementById('enrichment-breakdown');
      if (breakdownEl && recipe.enrichmentWater.breakdown.length > 0) {
        breakdownEl.innerHTML = recipe.enrichmentWater.breakdown.join(' · ');
      }
    }

    // Update enrichment tip based on what's enabled
    const tipEl = document.getElementById('enrichment-tip');
    if (tipEl) {
      if (enrichmentState.fat.enabled && enrichmentState.fat.percent > 15) {
        tipEl.textContent = 'High fat content: Add butter in stages after initial gluten development.';
      } else if (enrichmentState.sweet.enabled && enrichmentState.sweet.percent > 10) {
        tipEl.textContent = 'High sugar may slow yeast. Consider using osmotolerant yeast for very sweet doughs.';
      } else if (enrichmentState.eggs.enabled) {
        tipEl.textContent = 'Eggs add richness and help with browning. Room temperature eggs incorporate better.';
      } else {
        tipEl.textContent = 'Add fats after initial gluten development for better dough structure.';
      }
    }
  }

  // ============================================
  // Flour Management Event Listeners
  // ============================================

  let activeFlourSlots = 1;

  // Add flour button
  document.getElementById('add-flour-btn')?.addEventListener('click', () => {
    if (activeFlourSlots < 3) {
      activeFlourSlots++;
      const slot = document.getElementById(`flour-slot-${activeFlourSlots - 1}`);
      if (slot) {
        slot.classList.remove('hidden');
        // Set default percent
        const input = slot.querySelector('.flour-percent-input') as HTMLInputElement;
        if (input) {
          input.value = '0';
          flourBlend[activeFlourSlots - 1] = {
            type: (slot.querySelector('.flour-type-select') as HTMLSelectElement)?.value || 'whole-wheat',
            percent: 0
          };
        }
      }
      // Hide add button if at max
      if (activeFlourSlots >= 3) {
        document.getElementById('add-flour-btn')?.classList.add('hidden');
      }
      validateFlourPercents();
    }
  });

  // Remove flour buttons
  document.querySelectorAll('.remove-flour-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const index = parseInt((btn as HTMLElement).dataset.flour || '0');
      const slot = document.getElementById(`flour-slot-${index}`);
      if (slot) {
        slot.classList.add('hidden');
        // Reset this flour entry
        flourBlend[index] = { type: 'bread', percent: 0 };
        // Reset input
        const input = slot.querySelector('.flour-percent-input') as HTMLInputElement;
        if (input) input.value = '0';
      }
      activeFlourSlots--;
      document.getElementById('add-flour-btn')?.classList.remove('hidden');
      validateFlourPercents();
      updateUI();
    });
  });

  // Flour type selects
  document.querySelectorAll('.flour-type-select').forEach(select => {
    select.addEventListener('change', (e) => {
      const index = parseInt((e.target as HTMLSelectElement).dataset.flour || '0');
      flourBlend[index] = flourBlend[index] || { type: 'bread', percent: 0 };
      flourBlend[index].type = (e.target as HTMLSelectElement).value;
      updateFlourDisplay();
      updateUI();
    });
  });

  // Flour percent inputs
  document.querySelectorAll('.flour-percent-input').forEach(input => {
    input.addEventListener('input', (e) => {
      const index = parseInt((e.target as HTMLInputElement).dataset.flour || '0');
      flourBlend[index] = flourBlend[index] || { type: 'bread', percent: 0 };
      flourBlend[index].percent = parseInt((e.target as HTMLInputElement).value) || 0;
      validateFlourPercents();
      updateFlourDisplay();
      updateUI();
    });
  });

  // Validate flour percentages sum to 100
  function validateFlourPercents() {
    const total = flourBlend.reduce((sum, f) => sum + (f?.percent || 0), 0);
    const validationEl = document.getElementById('flour-validation');
    if (validationEl) {
      if (total !== 100) {
        validationEl.classList.remove('hidden');
        validationEl.textContent = `Total flour must equal 100% (currently ${total}%)`;
      } else {
        validationEl.classList.add('hidden');
      }
    }
  }

  // Update flour display (whole grain calculation)
  function updateFlourDisplay() {
    const wholeGrainPercent = calculateWholeGrainPercent();
    const totalWholeGrainEl = document.getElementById('total-whole-grain');
    if (totalWholeGrainEl) {
      totalWholeGrainEl.textContent = `${wholeGrainPercent}%`;
    }

    const tipEl = document.getElementById('whole-grain-tip');
    if (tipEl) {
      if (wholeGrainPercent > 30) {
        tipEl.textContent = 'High whole grain: Add 5-10% more water and consider a longer autolyse.';
      } else if (wholeGrainPercent > 10) {
        tipEl.textContent = 'Consider adding 2-5% more hydration for whole grains.';
      } else {
        tipEl.textContent = 'Mostly white flour: Standard hydration should work well.';
      }
    }

    // Update state.wholeGrain for recipe calculations
    state.wholeGrain = wholeGrainPercent;
  }

  // Flour preset blends
  document.querySelectorAll('.flour-preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const blend = (btn as HTMLElement).dataset.blend;

      // Reset all flour slots
      document.querySelectorAll('.flour-entry').forEach((entry, i) => {
        if (i > 0) entry.classList.add('hidden');
      });
      activeFlourSlots = 1;

      if (blend === 'classic') {
        flourBlend[0] = { type: 'bread', percent: 100 };
        flourBlend[1] = { type: 'whole-wheat', percent: 0 };
      } else if (blend === 'country') {
        flourBlend[0] = { type: 'bread', percent: 90 };
        flourBlend[1] = { type: 'whole-wheat', percent: 10 };
        document.getElementById('flour-slot-1')?.classList.remove('hidden');
        activeFlourSlots = 2;
      } else if (blend === 'multigrain') {
        flourBlend[0] = { type: 'bread', percent: 70 };
        flourBlend[1] = { type: 'whole-wheat', percent: 20 };
        flourBlend[2] = { type: 'rye-light', percent: 10 };
        document.getElementById('flour-slot-1')?.classList.remove('hidden');
        document.getElementById('flour-slot-2')?.classList.remove('hidden');
        activeFlourSlots = 3;
      }

      // Update UI inputs
      flourBlend.forEach((flour, i) => {
        const typeSelect = document.querySelector(`.flour-type-select[data-flour="${i}"]`) as HTMLSelectElement;
        const percentInput = document.querySelector(`.flour-percent-input[data-flour="${i}"]`) as HTMLInputElement;
        if (typeSelect) typeSelect.value = flour.type;
        if (percentInput) percentInput.value = String(flour.percent);
      });

      document.getElementById('add-flour-btn')?.classList.toggle('hidden', activeFlourSlots >= 3);
      validateFlourPercents();
      updateFlourDisplay();
      updateUI();
    });
  });

  // Sliders
  document.getElementById('hydration-slider')?.addEventListener('input', (e) => {
    state.hydration = parseFloat((e.target as HTMLInputElement).value);
    updateUI();
  });

  document.getElementById('whole-grain-slider')?.addEventListener('input', (e) => {
    state.wholeGrain = parseFloat((e.target as HTMLInputElement).value);
    updateUI();
  });

  document.getElementById('salt-slider')?.addEventListener('input', (e) => {
    state.salt = parseFloat((e.target as HTMLInputElement).value);
    updateUI();
  });

  // Unit toggle
  document.getElementById('unit-g')?.addEventListener('click', () => {
    state.unit = 'g';
    document.getElementById('unit-g')?.classList.add('bg-[var(--espresso)]', 'text-white');
    document.getElementById('unit-g')?.classList.remove('text-[var(--crust-brown)]');
    document.getElementById('unit-oz')?.classList.remove('bg-[var(--espresso)]', 'text-white');
    document.getElementById('unit-oz')?.classList.add('text-[var(--crust-brown)]');
    updateUI();
  });

  document.getElementById('unit-oz')?.addEventListener('click', () => {
    state.unit = 'oz';
    document.getElementById('unit-oz')?.classList.add('bg-[var(--espresso)]', 'text-white');
    document.getElementById('unit-oz')?.classList.remove('text-[var(--crust-brown)]');
    document.getElementById('unit-g')?.classList.remove('bg-[var(--espresso)]', 'text-white');
    document.getElementById('unit-g')?.classList.add('text-[var(--crust-brown)]');
    updateUI();
  });

  // Toast helper
  function showToast(message: string) {
    const toast = document.getElementById('toast');
    if (toast) {
      toast.textContent = message;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }
  }

  // Action buttons
  document.getElementById('btn-print')?.addEventListener('click', () => {
    window.print();
  });

  document.getElementById('btn-copy')?.addEventListener('click', async () => {
    const recipe = calculateRecipe();
    const styleName = state.style.charAt(0).toUpperCase() + state.style.slice(1);
    const text = `${styleName} Bread Recipe\n\nMakes ${state.numLoaves} loaves\n\nIngredients:\n- Flour: ${recipe.flourWeight}g (100%)\n- Water: ${recipe.waterWeight}g (${state.hydration}%)\n- Salt: ${recipe.saltWeight}g (${state.salt}%)\n- ${state.yeastType === 'starter' ? 'Starter' : 'Yeast'}: ${recipe.yeastWeight}g (${state.yeastPercent}%)\n\nInstructions:\n${state.instructions.map((inst, i) => `${i + 1}. ${inst}`).join('\n')}\n\nGenerated by The Dough Formula - thedoughformula.com`;

    try {
      await navigator.clipboard.writeText(text);
      showToast('Recipe copied to clipboard!');
    } catch {
      showToast('Could not copy recipe');
    }
  });

  document.getElementById('btn-share')?.addEventListener('click', async () => {
    const url = new URL(window.location.href);
    url.searchParams.set('style', state.style);
    url.searchParams.set('loaves', String(state.numLoaves));
    url.searchParams.set('weight', String(state.loafWeight));
    url.searchParams.set('hydration', String(state.hydration));

    try {
      await navigator.clipboard.writeText(url.toString());
      showToast('Recipe link copied!');
    } catch {
      showToast('Could not copy link');
    }
  });

  // FAQ toggles
  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const content = trigger.nextElementSibling;
      const chevron = trigger.querySelector('.faq-chevron') as HTMLElement;
      if (content && chevron) {
        content.classList.toggle('hidden');
        chevron.style.transform = content.classList.contains('hidden') ? '' : 'rotate(180deg)';
      }
    });
  });

  // Mobile menu
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.remove('translate-x-full');
  });

  document.getElementById('mobile-menu-close')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.add('translate-x-full');
  });

  document.querySelectorAll('.mobile-menu-link').forEach(link => {
    link.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.add('translate-x-full');
    });
  });

  // Newsletter form
  document.getElementById('newsletter-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    showToast("You're in! Check your inbox.");
  });

  // Load recipe from URL params
  function loadFromURL() {
    const params = new URLSearchParams(window.location.search);
    if (params.has('style')) {
      const styleCard = document.querySelector(`[data-style="${params.get('style')}"]`) as HTMLElement;
      if (styleCard) {
        styleCard.click();
      }
    }
    if (params.has('loaves')) {
      state.numLoaves = parseInt(params.get('loaves') || '2');
      (document.getElementById('num-loaves') as HTMLInputElement).value = String(state.numLoaves);
    }
    if (params.has('weight')) {
      state.loafWeight = parseInt(params.get('weight') || '900');
      (document.getElementById('loaf-weight') as HTMLInputElement).value = String(state.loafWeight);
    }
    if (params.has('hydration')) {
      state.hydration = parseFloat(params.get('hydration') || '75');
      (document.getElementById('hydration-slider') as HTMLInputElement).value = String(state.hydration);
    }
    updateUI();
  }

  // Initialize
  loadFromURL();
  updateYeastTypeButtons();
  updateMixerButtons();
  updateTempUnitToggle();
  updateUI();
</script>
