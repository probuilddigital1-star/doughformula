  // Update preferment UI elements
  function updatePrefermentUI() {
    const controls = document.getElementById('preferment-controls');
    const percentValue = document.getElementById('preferment-percent-value');
    const infoTitle = document.getElementById('preferment-info-title');
    const infoDesc = document.getElementById('preferment-info-desc');
    const prefTime = document.getElementById('preferment-time');
    const readySigns = document.getElementById('preferment-ready-signs');
    const startTime = document.getElementById('preferment-start-time');
    const prefTip = document.getElementById('preferment-tip');
    const prefFlourWeight = document.getElementById('preferment-flour-weight');
    const prefWaterWeight = document.getElementById('preferment-water-weight');
    const prefYeastWeight = document.getElementById('preferment-yeast-weight');

    if (state.prefermentType === 'none') {
      controls?.classList.add('hidden');
      return;
    }

    controls?.classList.remove('hidden');

    const prefData = PREFERMENT_DATA[state.prefermentType];
    if (!prefData) return;

    // Update percentage display
    if (percentValue) percentValue.textContent = `${state.prefermentPercent}%`;

    // Update info
    if (infoTitle) infoTitle.textContent = prefData.name;
    if (infoDesc) infoDesc.textContent = prefData.description;

    // Update timing
    const timing = estimatePrefermentTiming();
    if (prefTime) prefTime.textContent = timing.fermentTime;
    if (readySigns) readySigns.textContent = prefData.readySigns;
    if (startTime) startTime.textContent = timing.startTime;
    if (prefTip) prefTip.textContent = prefData.tip;

    // Calculate and update preferment ingredients
    const recipe = calculateRecipe();
    const prefIngredients = calculatePrefermentIngredients(recipe.flourWeight);
    if (prefIngredients) {
      if (prefFlourWeight) prefFlourWeight.textContent = `${prefIngredients.flour}g`;
      if (prefWaterWeight) prefWaterWeight.textContent = `${prefIngredients.water}g`;
      if (prefYeastWeight) {
        const yeastText = state.prefermentType === 'levain'
          ? `${prefIngredients.yeast}g ${prefIngredients.yeastNote}`
          : prefIngredients.yeast < 1
            ? `${prefIngredients.yeast}g ${prefIngredients.yeastNote}`
            : `${prefIngredients.yeast}g`;
        prefYeastWeight.textContent = yeastText;
      }
    }
  }

