---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "The Dough Formula | Bread Calculator with Baker's Percentages",
  description = "Free bread dough calculator using baker's percentages. Perfect recipes for sourdough, baguettes, focaccia, and more. Master the art of artisan bread baking.",
  image = "/og-image.jpg"
} = Astro.props;

const siteUrl = "https://thedoughformula.com";
const fullImageUrl = `${siteUrl}${image}`;

// JSON-LD Structured Data for WebApplication (Bread Calculator)
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "The Dough Formula",
  "description": description,
  "url": siteUrl,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web Browser",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "creator": {
    "@type": "Organization",
    "name": "The Dough Formula"
  },
  "featureList": [
    "Baker's percentage calculator",
    "Multiple bread styles (sourdough, baguette, focaccia, ciabatta)",
    "Preferment support (poolish, biga, levain)",
    "Water temperature calculator",
    "Fermentation timing estimates",
    "Baking schedule generator"
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <style>html{-ms-overflow-style:none;scrollbar-width:none}html::-webkit-scrollbar{display:none}</style>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Mobile Theme -->
    <meta name="theme-color" content="#FAF7F2" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Dough Formula" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="bread calculator, baker's percentage, sourdough calculator, bread recipe, baguette dough, focaccia recipe, artisan bread" />
    <link rel="canonical" href="https://thedoughformula.com" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="The Dough Formula" />
    <meta property="og:image" content={fullImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="The Dough Formula - Professional Bread Calculator" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageUrl} />
    <meta name="twitter:image:alt" content="The Dough Formula - Professional Bread Calculator" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Preload critical Fraunces font file (used in hero LCP text) -->
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/fraunces/v32/6NUu8FyLNQOQZAnv9bYEvDiIdE9Ea92uemAk_WBq8U_9v0c2Wa0K7iN7hzFUPJH58nib1433ZfxGw.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Load Google Fonts without blocking render -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500;1,9..144,600&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500;1,9..144,600&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500;1,9..144,600&display=swap" rel="stylesheet" />
    </noscript>


    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="flour-dusted min-h-screen">
    <!-- Skip to main content link for accessibility -->
    <a href="#calculator" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-[var(--espresso)] focus:text-white focus:px-4 focus:py-2 focus:rounded-md">
      Skip to calculator
    </a>
    <slot />
  </body>
</html>
